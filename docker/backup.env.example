# =============================================================================
# aktenraum — backup service environment configuration
# Copy this file to backup.env and fill in the REQUIRED values.
# =============================================================================

# REQUIRED: Passphrase that encrypts the restic repository.
# Store this somewhere safe (password manager). Without it you cannot restore.
RESTIC_PASSWORD=

# Postgres credentials (must match docker/.env)
PAPERLESS_DBUSER=paperless
# REQUIRED
PAPERLESS_DBPASS=

# -----------------------------------------------------------------------------
# Optional: B2 remote backup
# If BACKUP_B2_BUCKET is set, snapshots are also copied to Backblaze B2.
# -----------------------------------------------------------------------------
# BACKUP_B2_BUCKET=
# RESTIC_REPOSITORY_2=b2:your-bucket-name:/aktenraum
# B2_ACCOUNT_ID=
# B2_ACCOUNT_KEY=
