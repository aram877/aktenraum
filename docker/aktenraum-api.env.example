# Copy to docker/aktenraum-api.env and fill in. File should be chmod 600.

# DATABASE_URL is set in docker-compose.yml using PAPERLESS_DB* from .env so
# database credentials live in one place. Override here only if you need a
# non-default DSN.

# REQUIRED. Generate with: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRES_SECONDS=28800

# First-startup user seed. Once a user exists in the DB these are ignored,
# so it is safe to leave them set across restarts (or clear them after first boot).
BOOTSTRAP_USERNAME=admin
BOOTSTRAP_PASSWORD=

# Cookie attributes
COOKIE_NAME=aktenraum_session
# Set to true once you put the stack behind HTTPS (e.g. Tailscale + caddy).
COOKIE_SECURE=false

LOG_LEVEL=INFO

# ----- AI features (Phase 2: natural-language search) -----
# When unset, /api/ai/* responds 503; auth + health stay green.

# Internal Paperless URL inside the compose network. Override only for non-default deploys.
PAPERLESS_BASE_URL=http://paperless:8000
# Paperless API token (mint via /api/token/ — see CLAUDE.md). Same value as auto-tagger uses.
PAPERLESS_API_TOKEN=

# How long to cache the correspondent list inlined into the search prompt.
CORRESPONDENT_LIST_TTL_SECONDS=300

# Reprocess: aktenraum-api → auto-tagger webhook (POST /trigger/extract).
# Defaults to the in-cluster auto-tagger; override only for non-default deploys.
AUTO_TAGGER_URL=http://auto-tagger:8001
# Optional shared secret. Must match WEBHOOK_SECRET in docker/auto-tagger.env.
# Empty disables auth on both sides — fine for personal localhost.
WEBHOOK_SECRET=

# LLM backend selection — same env knob the auto-tagger uses.
# anthropic | ollama
LLM_BACKEND=anthropic

# Anthropic backend (used when LLM_BACKEND=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama backend (used when LLM_BACKEND=ollama). Default talks to host Ollama
# from inside the compose network.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
# Optional. When set, /api/ai/answer (Q&A) uses this model instead of OLLAMA_MODEL.
# Pair a fast small model (filter extraction) with a smarter big model (answer
# generation) — the answer step is the one that needs real reasoning.
OLLAMA_ANSWER_MODEL=
# Same split for Anthropic; leave empty to reuse ANTHROPIC_MODEL for both calls.
ANTHROPIC_ANSWER_MODEL=
