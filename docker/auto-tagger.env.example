# =============================================================================
# aktenraum — auto-tagger service environment configuration
# Copy this file to auto-tagger.env and fill in the REQUIRED values.
# =============================================================================

# -----------------------------------------------------------------------------
# Paperless connection
# -----------------------------------------------------------------------------

# REQUIRED: Base URL of the Paperless instance (no trailing slash)
PAPERLESS_BASE_URL=http://paperless:8000

# REQUIRED: API token — create in Paperless UI under Settings > API
PAPERLESS_API_TOKEN=

# -----------------------------------------------------------------------------
# LLM backend
# -----------------------------------------------------------------------------

# "anthropic" (default) or "ollama"
LLM_BACKEND=anthropic

# Anthropic — used when LLM_BACKEND=anthropic
# REQUIRED if LLM_BACKEND=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama — used when LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# -----------------------------------------------------------------------------
# Polling and processing
# -----------------------------------------------------------------------------

POLL_INTERVAL_SECONDS=30
BATCH_SIZE=5

# Propagation watcher: when true (default), the service runs a second polling
# loop that finds documents tagged `ai-approved`, copies their AI custom field
# values onto native Paperless entities (correspondent, document type,
# created_date, tags), and swaps the tag for `ai-propagated` (or
# `ai-propagation-error` on failure). Set to false to run extraction only.
ENABLE_PROPAGATION=true

# -----------------------------------------------------------------------------
# Confidence-based routing
# -----------------------------------------------------------------------------

# Documents whose extraction confidence is at or above AUTO_APPROVE_CONFIDENCE
# AND whose document_type is in AUTO_APPROVE_TYPES skip the human review queue
# and are tagged `ai-approved` directly. The propagation watcher then writes
# native Paperless fields automatically.
#
# AUTO_APPROVE_TYPES is a comma-separated list of DocumentType values
# (Rechnung, Kontoauszug, Gehaltsabrechnung, Mahnung, Vertrag, Versicherung,
# Steuer, Bescheid, Behoerdenbrief, Kfz, Arztbrief, Garantie, Urkunde,
# Ausweis, Zeugnis, Arbeitszeugnis, Mitgliedschaft, Nebenkostenabrechnung,
# Kuendigung, Sonstiges).
#
# Default: empty list — auto-approve disabled. Opt in by listing the routine,
# low-risk types you trust the model to classify correctly:
# AUTO_APPROVE_TYPES=Rechnung,Kontoauszug,Gehaltsabrechnung
AUTO_APPROVE_CONFIDENCE=0.95
AUTO_APPROVE_TYPES=

# Extractions below this confidence are tagged `ai-low-confidence` in addition
# to `ai-pending`, so you can prioritise them in the review queue.
LOW_CONFIDENCE_THRESHOLD=0.6

# Few-shot examples: when > 0, each extraction prepends N most-recently-
# propagated documents (text excerpt + their AI extraction as JSON) to the
# system prompt. Anchors the model on real, user-vetted output style. Useful
# especially with smaller local models (gemma, qwen, llama 3B/8B) which gain
# more from few-shot than frontier models. Each example adds ~500-700 tokens
# to the prompt; budget accordingly. 0 = disabled.
#
# Recommended default: 3. Anchors the model on three of your most-recently
# propagated docs (real corrections you've approved), which is the cheapest
# way to fix the doc_type misclassifications that drive users to fall back
# on tag-based search. Bump to 5+ once your propagated corpus is large
# enough to provide diverse exemplars; drop to 0 only if prompt latency
# becomes an issue.
FEW_SHOT_EXAMPLES=3

# Per-correspondent history hint: when true (default), the auto-tagger checks
# whether the document mentions a known correspondent from your propagated
# corpus and prepends a hint to the prompt naming the dominant past
# document_type (e.g. "Documents from 'GitHub, Inc.' have previously been
# classified as Rechnung in 5 of 5 cases"). Drives corpus-driven
# classification without model retraining.
USE_CORRESPONDENT_HISTORY=true

# -----------------------------------------------------------------------------
# Webhook listener
# -----------------------------------------------------------------------------

# When true (default) the auto-tagger starts an HTTP server on HTTP_PORT.
# Paperless's post_consume_script POSTs the doc id to /trigger/extract here
# so extraction begins within seconds instead of waiting for the next 30s
# poll. The poller still runs as a safety net for missed events.
ENABLE_HTTP_SERVER=true
HTTP_PORT=8001

# Optional shared secret. When non-empty, requests must include the same
# value in `X-Aktenraum-Secret`; missing/wrong → 401. Empty disables auth.
# Should match WEBHOOK_SECRET in docker/.env if you set one.
WEBHOOK_SECRET=

# Approximate token limit for document text sent to the LLM
# (estimated as characters / 4). Text is truncated at this limit.
MAX_TOKENS_INPUT=8000

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
