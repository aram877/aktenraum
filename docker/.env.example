# =============================================================================
# aktenraum — Paperless-ngx environment configuration
#
# DON'T copy this file by hand. Run `bash scripts/bootstrap-secrets.sh` from
# the repo root — it copies the template to docker/.env, generates every
# REQUIRED secret with `openssl rand`, prints the auto-generated admin
# password ONCE, and is idempotent so re-runs are safe no-ops. Per ADR-002
# (`docs/adr/002-distribution-desktop-app.md`) the same script will run on
# every desktop-app launch as a safety net.
# =============================================================================

# -----------------------------------------------------------------------------
# Paperless-ngx core
# -----------------------------------------------------------------------------

# REQUIRED: Generate with: openssl rand -hex 32
PAPERLESS_SECRET_KEY=

# Default admin credentials (change after first login)
PAPERLESS_ADMIN_USER=admin
# REQUIRED
PAPERLESS_ADMIN_PASSWORD=

# URL Paperless is reachable at (used for email links, no trailing slash)
PAPERLESS_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
# REQUIRED
PAPERLESS_DBPASS=

# -----------------------------------------------------------------------------
# Localisation
# -----------------------------------------------------------------------------

TZ=Europe/Berlin
PAPERLESS_OCR_LANGUAGE=deu+eng
PAPERLESS_DATE_ORDER=DMY
PAPERLESS_DEFAULT_CURRENCY=EUR

# -----------------------------------------------------------------------------
# OCR and document processing
# -----------------------------------------------------------------------------

# Rotate pages with >10° skew automatically
PAPERLESS_OCR_ROTATE_PAGES=true
PAPERLESS_OCR_ROTATE_PAGES_THRESHOLD=6

# Enable PDF/A conversion for long-term archival
PAPERLESS_OCR_OUTPUT_TYPE=pdfa
PAPERLESS_OCR_CLEAN=clean
PAPERLESS_OCR_DESKEW=true

# Number of OCR worker threads (tune to CPU count)
PAPERLESS_TASK_WORKERS=2
PAPERLESS_THREADS_PER_WORKER=1

# -----------------------------------------------------------------------------
# Networking (localhost-only by default)
# TODO: Add reverse proxy + Tailscale config here when ready
# -----------------------------------------------------------------------------

# Leave empty to bind to all interfaces only if behind a trusted proxy
# PAPERLESS_ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Privacy & telemetry
# -----------------------------------------------------------------------------

# Disable update checks (no external calls)
PAPERLESS_DISABLE_REGULAR_LOGIN=false
PAPERLESS_ENABLE_COMPRESSION=true

# -----------------------------------------------------------------------------
# Webhook between Paperless's post_consume_script and the auto-tagger.
# When non-empty, the script sends this in `X-Aktenraum-Secret` and the
# auto-tagger requires it to match WEBHOOK_SECRET (in auto-tagger.env). Empty
# value disables auth — fine for the default localhost-only stack.
# -----------------------------------------------------------------------------
WEBHOOK_SECRET=
