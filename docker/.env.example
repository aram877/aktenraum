# =============================================================================
# aktenraum — Paperless-ngx environment configuration
#
# DON'T copy this file by hand. Run `bash scripts/bootstrap-secrets.sh` from
# the repo root — it copies the template to docker/.env, generates every
# REQUIRED secret with `openssl rand`, prints the auto-generated admin
# password ONCE, and is idempotent so re-runs are safe no-ops. Per ADR-002
# (`docs/adr/002-distribution-desktop-app.md`) the same script will run on
# every desktop-app launch as a safety net.
# =============================================================================

# -----------------------------------------------------------------------------
# Paperless-ngx core
# -----------------------------------------------------------------------------

# REQUIRED: Generate with: openssl rand -hex 32
PAPERLESS_SECRET_KEY=

# Default admin credentials (change after first login)
PAPERLESS_ADMIN_USER=admin
# REQUIRED
PAPERLESS_ADMIN_PASSWORD=

# URL Paperless is reachable at (used for email links, no trailing slash)
PAPERLESS_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
# REQUIRED
PAPERLESS_DBPASS=

# -----------------------------------------------------------------------------
# Localisation
# -----------------------------------------------------------------------------

TZ=Europe/Berlin
PAPERLESS_OCR_LANGUAGE=deu+eng
PAPERLESS_DATE_ORDER=DMY
PAPERLESS_DEFAULT_CURRENCY=EUR

# -----------------------------------------------------------------------------
# OCR and document processing
# -----------------------------------------------------------------------------

# Rotate pages with >10° skew automatically
PAPERLESS_OCR_ROTATE_PAGES=true
PAPERLESS_OCR_ROTATE_PAGES_THRESHOLD=6

# Enable PDF/A conversion for long-term archival
PAPERLESS_OCR_OUTPUT_TYPE=pdfa
PAPERLESS_OCR_CLEAN=clean
PAPERLESS_OCR_DESKEW=true

# Number of OCR worker threads (tune to CPU count)
PAPERLESS_TASK_WORKERS=2
PAPERLESS_THREADS_PER_WORKER=1

# -----------------------------------------------------------------------------
# Networking (localhost-only by default)
# TODO: Add reverse proxy + Tailscale config here when ready
# -----------------------------------------------------------------------------

# Leave empty to bind to all interfaces only if behind a trusted proxy
# PAPERLESS_ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Privacy & telemetry
# -----------------------------------------------------------------------------

# Disable update checks (no external calls)
PAPERLESS_DISABLE_REGULAR_LOGIN=false
PAPERLESS_ENABLE_COMPRESSION=true

# -----------------------------------------------------------------------------
# Data directory
# -----------------------------------------------------------------------------
#
# Root for ALL persistent volumes (paperless data/media/export/consume,
# postgres pgdata, qdrant storage, restic repo). Defaults to
# `${HOME}/aktenraum` when unset, which matches the historical layout. The
# Tauri desktop shell (per ADR-002) writes the OS-appropriate default here
# at first launch (e.g. ~/Library/Application Support/aktenraum on macOS,
# %APPDATA%\aktenraum on Windows) so the user can pick a location at install
# time.
#
# IMPORTANT — Windows self-hosted installs MUST set this to an explicit
# Windows path (e.g. D:/aktenraum). Without it, ${HOME} resolves differently
# depending on how docker compose is invoked (Git Bash vs PowerShell vs Task
# runner), causing the data directory to change between runs — postgres
# initialises a fresh empty database at the new path, silently abandoning the
# old one. Set this once; never change it without migrating data first.
AKTENRAUM_DATA_DIR=

# -----------------------------------------------------------------------------
# Webhook between Paperless's post_consume_script and the auto-tagger.
# When non-empty, the script sends this in `X-Aktenraum-Secret` and the
# auto-tagger requires it to match WEBHOOK_SECRET (in auto-tagger.env). Empty
# value disables auth — fine for the default localhost-only stack.
# -----------------------------------------------------------------------------
WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Email ingestion (optional — IMAP)
#
# When AKTENRAUM_MAIL_IMAP_SERVER is set, `scripts/bootstrap-paperless.sh`
# provisions a Paperless mail account + rule pointing at this mailbox.
# Paperless polls it every ~10 minutes and consumes attachments through the
# same pipeline as the consume/ folder — the auto-tagger picks them up and
# they land in the inbox for review. Each ingested doc gets the
# `email-ingested` tag for provenance (filter `?tags=email-ingested` in
# Library to see them).
#
# Leave AKTENRAUM_MAIL_IMAP_SERVER empty (the default) to disable.
# -----------------------------------------------------------------------------

# IMAP server hostname. Empty disables email ingestion entirely.
# Examples: imap.gmail.com, outlook.office365.com, imap.fastmail.com
AKTENRAUM_MAIL_IMAP_SERVER=

# IMAP port. 993 = IMAPS (default). 143 = plain or STARTTLS.
AKTENRAUM_MAIL_IMAP_PORT=993

# IMAP security: SSL (default, port 993) | STARTTLS (port 143) | NONE
AKTENRAUM_MAIL_IMAP_SECURITY=SSL

# Mailbox credentials. For Gmail/Google Workspace use an App Password (not
# your account password) — https://myaccount.google.com/apppasswords.
# For Office 365 you may need OAuth2; for plain IMAP a regular password works.
AKTENRAUM_MAIL_USERNAME=
AKTENRAUM_MAIL_PASSWORD=

# Folder to poll. Most providers use INBOX.
AKTENRAUM_MAIL_FOLDER=INBOX

# Display name for the mail account in Paperless's admin UI. Also used as the
# rule name (suffixed `-rule`). Change this if you provision multiple
# mailboxes manually — re-running with a different name creates a new
# account rather than reconciling the existing one.
AKTENRAUM_MAIL_NAME=aktenraum

# What Paperless does to each email after consuming attachments. The rule
# filter then skips mails in this state on subsequent polls, so each mail
# is processed exactly once.
#   MARK_READ          — mark as read (default; rule won't re-pick read mail)
#   FLAG               — flag/star it (rule won't re-pick flagged mail)
#   DELETE             — delete (irreversible — use only on a dedicated mailbox)
AKTENRAUM_MAIL_ACTION=MARK_READ

# Optional sender allowlist. Empty = accept all senders.
# Paperless matches as a case-insensitive substring against the From: header.
# Example: AKTENRAUM_MAIL_FILTER_FROM=billing@vodafone.de
AKTENRAUM_MAIL_FILTER_FROM=
