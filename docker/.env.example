# =============================================================================
# aktenraum — unified environment configuration
# =============================================================================
# DON'T copy this file by hand. Run `bash scripts/bootstrap-secrets.sh` from
# the repo root — it copies this template to docker/.env, generates every
# REQUIRED secret with `openssl rand`, prints the auto-generated passwords ONCE,
# and is idempotent so re-runs are safe no-ops.
# =============================================================================

# -----------------------------------------------------------------------------
# Data directory — MUST be an absolute path so Docker Desktop always finds the
# same location regardless of how compose is invoked.
#   Windows:        D:/aktenraum
#   macOS / Linux:  /Users/you/aktenraum   or   /srv/aktenraum
# REQUIRED — compose fails to start until this is set. Never change without
# migrating the data directory first.
# -----------------------------------------------------------------------------
AKTENRAUM_DATA_DIR=

# -----------------------------------------------------------------------------
# Paperless-ngx core
# -----------------------------------------------------------------------------

# REQUIRED: Generate with: openssl rand -hex 32
PAPERLESS_SECRET_KEY=
PAPERLESS_ADMIN_USER=admin
# REQUIRED
PAPERLESS_ADMIN_PASSWORD=
PAPERLESS_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
# REQUIRED
PAPERLESS_DBPASS=

# -----------------------------------------------------------------------------
# Localisation
# -----------------------------------------------------------------------------
TZ=Europe/Berlin
PAPERLESS_OCR_LANGUAGE=deu+eng
PAPERLESS_DATE_ORDER=DMY
PAPERLESS_DEFAULT_CURRENCY=EUR

# -----------------------------------------------------------------------------
# OCR and document processing
# -----------------------------------------------------------------------------
PAPERLESS_OCR_ROTATE_PAGES=true
PAPERLESS_OCR_ROTATE_PAGES_THRESHOLD=6
PAPERLESS_OCR_OUTPUT_TYPE=pdfa
PAPERLESS_OCR_CLEAN=clean
PAPERLESS_OCR_DESKEW=true
PAPERLESS_TASK_WORKERS=2
PAPERLESS_THREADS_PER_WORKER=1

# -----------------------------------------------------------------------------
# Privacy & telemetry
# -----------------------------------------------------------------------------
PAPERLESS_DISABLE_REGULAR_LOGIN=false
PAPERLESS_ENABLE_COMPRESSION=true

# -----------------------------------------------------------------------------
# Webhook secret — shared across: paperless post_consume → auto-tagger, and
# aktenraum-api → auto-tagger trigger. Empty disables auth.
# -----------------------------------------------------------------------------
WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Email ingestion (optional — IMAP)
# Leave AKTENRAUM_MAIL_IMAP_SERVER empty to disable entirely.
# For Gmail/Google Workspace use an App Password (not your account password):
# https://myaccount.google.com/apppasswords
# -----------------------------------------------------------------------------
AKTENRAUM_MAIL_IMAP_SERVER=
AKTENRAUM_MAIL_IMAP_PORT=993
AKTENRAUM_MAIL_IMAP_SECURITY=SSL
AKTENRAUM_MAIL_USERNAME=
AKTENRAUM_MAIL_PASSWORD=
AKTENRAUM_MAIL_FOLDER=INBOX
AKTENRAUM_MAIL_NAME=aktenraum
AKTENRAUM_MAIL_ACTION=MARK_READ
AKTENRAUM_MAIL_FILTER_FROM=

# -----------------------------------------------------------------------------
# Paperless API token — shared by auto-tagger (indexing) and aktenraum-api
# (AI search). Mint after first Paperless start: see CLAUDE.md.
# Internal URL stays http://paperless:8000 (compose network); don't change.
# -----------------------------------------------------------------------------
PAPERLESS_BASE_URL=http://paperless:8000
PAPERLESS_API_TOKEN=

# -----------------------------------------------------------------------------
# LLM backend — shared by auto-tagger (extraction) and aktenraum-api (search/answer)
# "ollama" | "anthropic"
#
# NOTE: the active extraction model is the DB quality-tier map in
# services/aktenraum-api/src/aktenraum_api/settings/quality.py — NOT OLLAMA_MODEL.
# OLLAMA_MODEL is only a fallback when aktenraum-api is unreachable.
# Recommended local model: qwen2.5:14b-instruct-q8_0 (~16 GB).
# -----------------------------------------------------------------------------
LLM_BACKEND=ollama
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional: use a bigger model for the /ask answer step only (8B too small for citations)
ANTHROPIC_ANSWER_MODEL=
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:14b-instruct-q8_0
# Optional: use a bigger model for the /ask answer step only
OLLAMA_ANSWER_MODEL=

# -----------------------------------------------------------------------------
# RAG — shared by auto-tagger (chunk indexing) and aktenraum-api (query embedding)
# EMBEDDING_MODEL must be identical for both roles. Changing to a model with a
# different vector dimension requires `task rag:reembed` to rebuild the index.
# Pull first: ollama pull qwen3-embedding:4b
# -----------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
EMBEDDING_MODEL=qwen3-embedding:4b

# -----------------------------------------------------------------------------
# Auto-tagger tuning
# -----------------------------------------------------------------------------
POLL_INTERVAL_SECONDS=30
BATCH_SIZE=5
ENABLE_PROPAGATION=true
# Legacy seed: read ONCE by the first Alembic migration to populate
# auto_approve_rules. Afterwards the DB table is the source of truth — edit
# per-type rules from /settings → Auto-Genehmigung in the SPA.
AUTO_APPROVE_CONFIDENCE=0.90
# Extractions below this confidence are tagged ai-low-confidence (surfaced in inbox).
LOW_CONFIDENCE_THRESHOLD=0.70
# Few-shot examples prepended to each extraction prompt (0 = disabled).
FEW_SHOT_EXAMPLES=3
# Prepend a hint about known correspondents from the propagated corpus.
USE_CORRESPONDENT_HISTORY=true
ENABLE_HTTP_SERVER=true
HTTP_PORT=8001
MAX_TOKENS_INPUT=8000
AKTENRAUM_API_URL=http://aktenraum-api:8002

# -----------------------------------------------------------------------------
# aktenraum-api
# DATABASE_URL is built by docker-compose.yml from PAPERLESS_DB* above.
# -----------------------------------------------------------------------------

# REQUIRED: Generate with: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRES_SECONDS=28800
BOOTSTRAP_USERNAME=admin
# REQUIRED
BOOTSTRAP_PASSWORD=
COOKIE_NAME=aktenraum_session
# COOKIE_SECURE controls whether the auth cookie requires HTTPS.
#   Leave unset (defaults true) for Tailscale remote access (HTTPS via MagicDNS).
#   Set to false for plain-HTTP localhost dev only (http://localhost:8080).
#   DO NOT set false to "fix" remote access over plain HTTP — use Tailscale instead.
# COOKIE_SECURE=false
CORRESPONDENT_LIST_TTL_SECONDS=300
AUTO_TAGGER_URL=http://auto-tagger:8001

# -----------------------------------------------------------------------------
# Backup (restic)
# REQUIRED: store RESTIC_PASSWORD somewhere safe — without it backups cannot
# be restored. bootstrap-secrets.sh generates this for you on first run.
# -----------------------------------------------------------------------------
RESTIC_PASSWORD=
# Optional: Backblaze B2 remote copy
# BACKUP_B2_BUCKET=
# RESTIC_REPOSITORY_2=b2:your-bucket-name:/aktenraum
# B2_ACCOUNT_ID=
# B2_ACCOUNT_KEY=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Resource limits (tune per host)
# -----------------------------------------------------------------------------
AUTO_TAGGER_MEM_LIMIT=3g
AKTENRAUM_API_MEM_LIMIT=6g

# -----------------------------------------------------------------------------
# Port overrides (tune per host — only needed if defaults conflict)
# -----------------------------------------------------------------------------
# AKTENRAUM_WEB_PORT=8080
# AKTENRAUM_QDRANT_PORT=6333
